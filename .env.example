# .env.example - Use este arquivo como template
# Copie para .env e preencha com seus valores reais
# NUNCA faça commit do .env com valores reais!

# Supabase Configuration
# Obtenha esses valores em: https://app.supabase.com/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_PROJECT_ID=seu_project_id_aqui
VITE_SUPABASE_PUBLISHABLE_KEY=sua_chave_anonima_aqui
VITE_SUPABASE_URL=https://seu_project.supabase.co

# Opcional: URL da aplicação para CORS
VITE_APP_URL=http://localhost:8080
