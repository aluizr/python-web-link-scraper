# .env.example — Copie para .env e preencha com seus valores reais
# NUNCA faça commit do .env com valores reais!

# ─── Supabase ────────────────────────────────────────────────────────────────
# Obtenha em: https://app.supabase.com/project/SEU_PROJETO/settings/api
SUPABASE_URL=https://seu_projeto.supabase.co
SUPABASE_KEY=sua_anon_key_aqui

# ─── Servidor ────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000

# ─── CORS ────────────────────────────────────────────────────────────────────
# Separar múltiplas origens com vírgula, ex: http://localhost:3000,https://meusite.com
CORS_ORIGINS=*
